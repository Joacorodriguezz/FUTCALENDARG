{
  "name": "partidos-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "scrape-promiedos": "ts-node --transpile-only src/scripts/scrapePromiedos.ts",
    "scrape-worldcup": "ts-node --transpile-only src/scripts/scrapeWorldCup.ts",
    "scrape-promiedos-wc": "ts-node --transpile-only src/scripts/scrapePromiedosWorldCup.ts",
    "dry-run": "ts-node --transpile-only src/scripts/dryRunScrape.ts",
    "upload-logos": "ts-node --transpile-only src/scripts/uploadLogos.ts",
    "scrape-leagues": "ts-node --transpile-only src/scripts/scrapeLeagues.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.18.0",
    "googleapis": "^144.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.14.0",
    "@types/sharp": "^0.31.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
