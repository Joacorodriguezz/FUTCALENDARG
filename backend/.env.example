# ─── Google OAuth ────────────────────────────────────────────────────────────
# Obtener en: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Requiere: Google Calendar API habilitada.
#
# REDIRECT URI:
#   Dev:  http://localhost:3001/api/auth/google/callback
#   Prod: https://<tu-backend>.railway.app/api/auth/google/callback  ← cambiar según tu hosting
#
# Ambas URIs deben estar en la lista de "Authorized redirect URIs" en Google Cloud Console.
# En Google Cloud Console también debés publicar el OAuth consent screen (pasar de "Testing"
# a "Production") para que cualquier usuario pueda autenticarse — en Testing solo 100 usuarios.
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ─── Sesión Express ───────────────────────────────────────────────────────────
# Cualquier string aleatorio largo (ej: generá uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your_random_session_secret_here

# ─── URLs ────────────────────────────────────────────────────────────────────
# Dev:  FRONTEND_URL=http://localhost:5173
# Prod: FRONTEND_URL=https://<tu-frontend>.vercel.app
FRONTEND_URL=http://localhost:5173
PORT=3001

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtener en: supabase.com → tu proyecto → Project Settings → API
# Project URL → SUPABASE_URL
# anon public  → SUPABASE_ANON_KEY  (usado por el backend Express en runtime)
# service_role → SUPABASE_SERVICE_ROLE_KEY (usado SOLO por el cron — tiene acceso total, no expongas en el frontend)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
