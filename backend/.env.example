# ─── Google OAuth ────────────────────────────────────────────────────────────
# Obtener en: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Requiere: Google Calendar API habilitada y redirect URI autorizado:
#   http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ─── Sesión Express ───────────────────────────────────────────────────────────
# Cualquier string aleatorio largo (ej: generá uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your_random_session_secret_here

# ─── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PORT=3001

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtener en: supabase.com → tu proyecto → Project Settings → API
# Project URL → SUPABASE_URL
# anon public  → SUPABASE_ANON_KEY  (usado por el backend Express en runtime)
# service_role → SUPABASE_SERVICE_ROLE_KEY (usado SOLO por el cron — tiene acceso total, no expongas en el frontend)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── API-Football ─────────────────────────────────────────────────────────────
# Obtener en: dashboard.api-football.com → My Access → API-KEY
# Plan gratuito: 100 req/día
# Usado SOLO por el cron script (fetchAndStore.ts), no por el backend Express
API_FOOTBALL_KEY=your_api_football_key_here
